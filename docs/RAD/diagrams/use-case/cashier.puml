@startuml SME_Ops_Use_Case_Cashier
title SME Ops — Use Cases: Cashier

actor Cashier as cashier

rectangle "SME Ops" {
  usecase "UC6 Record sale" as UC6
  usecase "UC7 Validate stock" as UC7
  usecase "UC8 Discount & payment" as UC8
  usecase "UC10 Sales history" as UC10
