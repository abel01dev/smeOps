# --- Server ---
NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:3000
# Expose Swagger UI at /docs when true (default: on in development only)
# SWAGGER_ENABLED=true

# --- Database (Supabase Postgres via Pooler) ---
# Project Settings -> Database -> Connect -> copy BOTH pooler URIs.
#
# LOCAL DEV (recommended if Prisma fails with P1001 on port 6543):
#   Set DATABASE_URL to the **Session pooler** (port 5432) — same string you use
#   for DIRECT_URL. Many networks block or intermittently drop port 6543
#   (Transaction pooler).
#
# PRODUCTION (Railway / Render):
#   DATABASE_URL = Transaction pooler (6543) + ?pgbouncer=true&connection_limit=1
#   DIRECT_URL   = Session pooler (5432) — required for `prisma migrate`
# Local dev (if pooler P1001): use the **direct** host from Database → Connection string:
#   postgresql://postgres:[PASSWORD]@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.PROJECT_REF.supabase.co:5432/postgres?connect_timeout=30&sslmode=require"
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.PROJECT_REF.supabase.co:5432/postgres?connect_timeout=30&sslmode=require"
# Pooler fallback (Session mode, port 5432 — user postgres.PROJECT_REF):
# DATABASE_URL="postgresql://postgres.PROJECT_REF:[PASSWORD]@aws-0-REGION.pooler.supabase.com:5432/postgres?connect_timeout=30&sslmode=require"

# --- Supabase Auth ---
# Project Settings -> API Keys (new) or Project Settings -> API (legacy)
SUPABASE_URL="https://PROJECT_REF.supabase.co"
SUPABASE_ANON_KEY="sb_publishable_..."        # or legacy "eyJ..." anon key (safe to expose)
SUPABASE_SERVICE_ROLE_KEY="sb_secret_..."     # or legacy "eyJ..." service_role (SECRET! backend only)
# Note: JWTs are verified via JWKS auto-fetched from SUPABASE_URL — no shared secret needed.

# --- AI assistant context ---
# Include full tenant JSON in chat context (sales, products, customers, expenses).
# On by default in development; set false in production to reduce token usage.
# AI_CONTEXT_INCLUDE_RAW=true
