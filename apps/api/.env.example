# --- Server ---
NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:3000

# --- Database (Supabase Postgres) ---
# Project Settings -> Database -> Connection string
# DATABASE_URL: use the "Transaction" pooler URI (port 6543) for runtime
# DIRECT_URL : use the "Session" / direct URI (port 5432) for migrations
DATABASE_URL="postgresql://postgres.PROJECT_REF:[YOUR-PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.PROJECT_REF:[YOUR-PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"

# --- Supabase Auth ---
# Project Settings -> API Keys (new) or Project Settings -> API (legacy)
SUPABASE_URL="https://PROJECT_REF.supabase.co"
SUPABASE_ANON_KEY="sb_publishable_..."        # or legacy "eyJ..." anon key (safe to expose)
SUPABASE_SERVICE_ROLE_KEY="sb_secret_..."     # or legacy "eyJ..." service_role (SECRET! backend only)
# Note: JWTs are verified via JWKS auto-fetched from SUPABASE_URL — no shared secret needed.
