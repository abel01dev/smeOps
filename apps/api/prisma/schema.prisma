// =====================================================================
// SME Ops Platform — Prisma schema
// ---------------------------------------------------------------------
// Design principles:
//  1. Multi-tenant by `organizationId` on every tenant-owned table.
//     A NestJS TenantGuard + Prisma client extension enforces scoping
//     at the application layer. (Row-Level Security can be layered on
//     in Postgres later without schema changes.)
//
//  2. All monetary values are PostgreSQL DECIMAL — never floats.
//     - Product / line-item amounts:  Decimal(12, 2)  -> up to 9,999,999,999.99
//     - Aggregates (sale total, totalSpent): Decimal(14, 2) for headroom
//
//  3. Historical accuracy: SaleItem snapshots productName, buyPriceAtSale,
//     and sellPriceAtSale at the moment of sale, so editing a product
//     later cannot rewrite history (revenue/profit reports stay stable).
//
//  4. Denormalized Sale.profit avoids a JOIN+SUM on every dashboard load.
//     The single source of truth is still SaleItem.lineProfit.
//
//  5. Deletion strategy:
//       Organization → cascade everything (delete a tenant -> delete all data)
//       Product      → onDelete: Restrict from SaleItem  (use ARCHIVED status)
//       Customer     → onDelete: SetNull from Sale      (preserve sale history)
//       Category     → onDelete: SetNull from Product   (preserve products)
// =====================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------------------- Tenancy & users ----------------------

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  currency  String   @default("ETB")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users            User[]
  categories       Category[]
  products         Product[]
  customers        Customer[]
  sales                 Sale[]
  customerPayments      CustomerPayment[]
  expenseCategories     ExpenseCategory[]
  operationalExpenses   OperationalExpense[]
  aiConversations       AIConversation[]
  aiMessages            AIMessage[]
  aiSettings            AISettings[]

  @@map("organizations")
}

// MANAGER = shop manager (full shop except owner-only team).
// INVENTORY_MANAGER = categories + products only (no POS/sales/customers/dashboard).
enum UserRole {
  OWNER
  MANAGER
  INVENTORY_MANAGER
  CASHIER
}

// User.id stores the Supabase `auth.users.id` (UUID). Passwords / email
// confirmation / resets are handled entirely by Supabase Auth; this row only
// holds business profile data (name, role) and the tenant link.
model User {
  id             String   @id @db.Uuid
  organizationId String
  email          String   @unique
  name           String
  role           UserRole @default(OWNER)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization          Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sales                 Sale[]                 @relation("CashierSales")
  recordedExpenses      OperationalExpense[]   @relation("RecordedExpenses")
  recordedCustomerPayments CustomerPayment[]   @relation("RecordedCustomerPayments")
  aiConversations       AIConversation[]
  aiSettings            AISettings[]

  @@index([organizationId])
  @@map("users")
}

// ---------------------- Inventory ----------------------

model Category {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  products     Product[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("categories")
}

enum ProductStatus {
  ACTIVE
  ARCHIVED
}

model Product {
  id             String        @id @default(cuid())
  organizationId String
  categoryId     String?
  name           String
  description    String?
  buyPrice       Decimal       @db.Decimal(12, 2)
  sellPrice      Decimal       @db.Decimal(12, 2)
  stockQuantity  Int           @default(0)
  minStock       Int           @default(0)
  status         ProductStatus @default(ACTIVE)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  category     Category?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  saleItems    SaleItem[]

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, name])
  @@index([categoryId])
  @@map("products")
}

// ---------------------- Customers ----------------------

model Customer {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  phone          String?
  address        String?
  totalSpent     Decimal  @default(0) @db.Decimal(14, 2)
  /// Sum of unpaid balances across credit sales (denormalized; updated in sale/payment txs).
  outstandingBalance Decimal @default(0) @db.Decimal(14, 2)
  /// Optional cap on total outstanding credit; null = no limit.
  creditLimit    Decimal? @db.Decimal(14, 2)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sales        Sale[]
  payments     CustomerPayment[]

  @@index([organizationId])
  @@index([organizationId, phone])
  @@map("customers")
}

// ---------------------- Sales / POS ----------------------

enum PaymentMethod {
  CASH
  MOBILE_MONEY // reserved for future use
  CARD         // reserved for future use
  CREDIT       // sale on account (buy now, pay later)
}

enum SalePaymentStatus {
  PAID
  PARTIAL
  UNPAID
}

model Sale {
  id             String            @id @default(cuid())
  organizationId String
  customerId     String?
  cashierId      String            @db.Uuid
  subtotal       Decimal           @db.Decimal(14, 2)
  discount       Decimal           @default(0) @db.Decimal(14, 2)
  total          Decimal           @db.Decimal(14, 2)
  profit         Decimal           @db.Decimal(14, 2)
  paymentMethod  PaymentMethod     @default(CASH)
  paymentStatus  SalePaymentStatus @default(PAID)
  amountPaid     Decimal           @default(0) @db.Decimal(14, 2)
  amountDue      Decimal           @default(0) @db.Decimal(14, 2)
  dueDate        DateTime?
  note           String?
  createdAt      DateTime          @default(now())

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer     Customer?         @relation(fields: [customerId], references: [id], onDelete: SetNull)
  cashier      User              @relation("CashierSales", fields: [cashierId], references: [id])
  items        SaleItem[]
  payments     CustomerPayment[]

  @@index([organizationId])
  @@index([organizationId, createdAt])
  @@index([organizationId, paymentStatus])
  @@index([customerId])
  @@map("sales")
}

/// Money collected against a credit sale (or customer balance).
model CustomerPayment {
  id             String        @id @default(cuid())
  organizationId String
  customerId     String
  saleId         String?
  amount         Decimal       @db.Decimal(14, 2)
  paymentMethod  PaymentMethod
  recordedById   String        @db.Uuid
  note           String?
  createdAt      DateTime      @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer     Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  sale         Sale?        @relation(fields: [saleId], references: [id], onDelete: SetNull)
  recordedBy   User         @relation("RecordedCustomerPayments", fields: [recordedById], references: [id])

  @@index([organizationId])
  @@index([customerId])
  @@index([saleId])
  @@map("customer_payments")
}

model SaleItem {
  id              String  @id @default(cuid())
  saleId          String
  productId       String
  productName     String
  quantity        Int
  buyPriceAtSale  Decimal @db.Decimal(12, 2)
  sellPriceAtSale Decimal @db.Decimal(12, 2)
  lineTotal       Decimal @db.Decimal(14, 2)
  lineProfit      Decimal @db.Decimal(14, 2)

  sale    Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([saleId])
  @@index([productId])
  @@map("sale_items")
}

// ---------------------- Operating expenses (OPEX) ----------------------
// Day-to-day costs: rent, salaries, transport, utilities — not capital assets.

model ExpenseCategory {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  expenses     OperationalExpense[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("expense_categories")
}

model OperationalExpense {
  id             String        @id @default(cuid())
  organizationId String
  categoryId     String
  recordedById   String        @db.Uuid
  amount         Decimal       @db.Decimal(14, 2)
  description    String?
  /// Calendar day the money was spent (stored at local midnight).
  expenseDate    DateTime
  paymentMethod  PaymentMethod @default(CASH)
  note           String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  category     ExpenseCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  recordedBy   User            @relation("RecordedExpenses", fields: [recordedById], references: [id])

  @@index([organizationId])
  @@index([organizationId, expenseDate])
  @@index([categoryId])
  @@map("operational_expenses")
}

// ---------------------- AI Business Assistant ----------------------

enum AIMessageRole {
  USER
  ASSISTANT
  SYSTEM
}

model AIConversation {
  id             String   @id @default(cuid())
  organizationId String
  userId         String   @db.Uuid
  title          String   @default("New conversation")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages     AIMessage[]

  @@index([organizationId, userId, updatedAt])
  @@map("ai_conversations")
}

model AIMessage {
  id             String        @id @default(cuid())
  conversationId String
  organizationId String
  role           AIMessageRole
  content        String        @db.Text
  /// Model id used for assistant replies (OpenRouter slug).
  model          String?
  createdAt      DateTime      @default(now())

  conversation AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([organizationId])
  @@map("ai_messages")
}

/// Per-user AI preferences within a tenant (API key stored encrypted server-side).
model AISettings {
  id                  String   @id @default(cuid())
  organizationId      String
  userId              String   @db.Uuid
  /// AES-256-GCM encrypted OpenRouter API key; never returned to clients.
  openRouterApiKeyEnc String?
  preferredModel      String   @default("openrouter/free")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@map("ai_settings")
}
