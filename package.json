{
  "name": "sme-ops-platform",
  "version": "0.1.0",
  "private": true,
  "description": "AI-Powered Business Operations Optimization SaaS for SMEs",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm --parallel --filter \"./apps/*\" dev",
    "dev:api": "pnpm --filter @sme/api dev",
    "dev:web": "pnpm --filter @sme/web dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "db:generate": "pnpm --filter @sme/api db:generate",
    "db:migrate": "pnpm --filter @sme/api db:migrate",
    "db:seed": "pnpm --filter @sme/api db:seed",
    "db:studio": "pnpm --filter @sme/api db:studio"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
